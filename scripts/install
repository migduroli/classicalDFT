#!/usr/bin/env bash
set -e

source scripts/str_lib.sh

BUILD_DIR="build-local"

# ── Package installation ────────────────────────────────────────────────────

install_deps_macos() {
  if ! command -v brew &>/dev/null; then
    message "error" "Homebrew not found. Install from https://brew.sh"
    exit 1
  fi

  message "info" "Installing dependencies via Homebrew"

  local packages=(cmake gsl armadillo fftw nlohmann-json eigen grace python3)
  for pkg in "${packages[@]}"; do
    if brew list --formula "$pkg" &>/dev/null; then
      message "success" "$pkg already installed"
    else
      brew install "$pkg"
      message "success" "Installed $pkg"
    fi
  done

  message "info" "Installing Python packages for matplotlib-cpp"
  pip3 install --quiet matplotlib numpy
  message "success" "matplotlib and numpy installed"

  if ! brew list --cask xquartz &>/dev/null; then
    message "warning" "XQuartz not found (required for Grace GUI)"
    message "info" "Install with: brew install --cask xquartz"
    message "info" "Then log out and back in to activate X11"
  else
    message "success" "XQuartz already installed"
  fi
}

install_deps_linux() {
  message "info" "Installing dependencies via apt"

  sudo apt-get -qq -y update
  sudo apt-get -qq -y install --no-install-recommends \
    build-essential \
    cmake \
    g++ \
    pkg-config \
    libgsl-dev \
    libarmadillo-dev \
    libeigen3-dev \
    libfftw3-dev \
    nlohmann-json3-dev \
    grace \
    python3-dev \
    python3-matplotlib \
    python3-numpy

  message "success" "All packages installed"
}

install_deps() {
  case "$(uname -s)" in
    Darwin) install_deps_macos ;;
    Linux)  install_deps_linux ;;
    *)
      message "error" "Unsupported OS: $(uname -s)"
      exit 1
      ;;
  esac
}

# ── Local build ─────────────────────────────────────────────────────────────

build_local() {
  message "info" "Configuring local build in $BUILD_DIR"

  cmake -B "$BUILD_DIR" \
    -DCMAKE_BUILD_TYPE=Release \
    -DDFT_BUILD_TESTS=ON \
    -DDFT_BUILD_DOCS=ON \
    -DDFT_USE_GRACE=ON \
    -DDFT_USE_MATPLOTLIB=ON

  message "info" "Building"

  cmake --build "$BUILD_DIR" --parallel

  message "success" "Build completed: $BUILD_DIR"
}

# ── Main ────────────────────────────────────────────────────────────────────

install() {
  message "info" "classicalDFT local install"
  install_deps
  build_local
  message "success" "Done. Run docs with: cd docs/<name> && make run-local"
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  install "$@"
fi
