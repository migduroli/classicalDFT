#!/usr/bin/env bash
set -e

source scripts/str_lib.sh

BUILD_DIR="build-coverage"
COVERAGE_DIR="coverage"

coverage() {
  for tool in cmake lcov genhtml; do
    if ! command -v "$tool" &>/dev/null; then
      message "error" "$tool is not available"
      exit 1
    fi
  done

  # Configure with coverage enabled
  message "info" "Configure (coverage)"
  cmake -B "$BUILD_DIR" \
    -DCMAKE_BUILD_TYPE=Debug \
    -DDFT_BUILD_TESTS=ON \
    -DDFT_BUILD_EXAMPLES=OFF \
    -DDFT_USE_GRACE=OFF \
    -DDFT_CODE_COVERAGE=ON
  message "success" "Configure completed"

  # Build
  message "info" "Build (coverage)"
  cmake --build "$BUILD_DIR" --parallel
  message "success" "Build completed"

  # Zero counters
  lcov --zerocounters --directory "$BUILD_DIR" --quiet

  # Run tests
  message "info" "Tests"
  ctest --test-dir "$BUILD_DIR" --output-on-failure
  message "success" "Tests completed"

  # lcov 2.x is strict about data consistency; suppress known-harmless warnings
  LCOV_IGNORE="--ignore-errors inconsistent,inconsistent,format,format,corrupt,corrupt,category,category,unsupported,unsupported"

  # Capture coverage
  message "info" "Coverage capture"
  lcov --capture \
    --directory "$BUILD_DIR" \
    --output-file "$BUILD_DIR/coverage.info" \
    --quiet \
    $LCOV_IGNORE

  # Filter: keep only project sources (include/ and src/)
  lcov --extract "$BUILD_DIR/coverage.info" \
    "*/include/dft_lib/*" \
    "*/src/*" \
    --output-file "$BUILD_DIR/coverage_filtered.info" \
    --quiet \
    --ignore-errors unused \
    $LCOV_IGNORE

  # Generate HTML report
  genhtml "$BUILD_DIR/coverage_filtered.info" \
    --output-directory "$COVERAGE_DIR" \
    --title "classicalDFT" \
    --quiet \
    $LCOV_IGNORE

  # Summary
  message "info" "Coverage summary"
  lcov --summary "$BUILD_DIR/coverage_filtered.info" $LCOV_IGNORE --ignore-errors empty 2>&1 | grep -E "lines|functions|branches"

  message "success" "Report: $COVERAGE_DIR/index.html"
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  coverage "$@"
fi
