#!/usr/bin/env bash
set -e

source scripts/str_lib.sh

BUILD_DIR="${BUILD_DIR:-build}"

test_local() {
  message "info" "Tests (local)"

  if [[ ! -d "$BUILD_DIR" ]]; then
    message "error" "Build directory not found. Run 'make build' first."
    exit 1
  fi

  ctest --test-dir "$BUILD_DIR" --output-on-failure
  message "success" "Tests completed"
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  test_local "$@"
fi
