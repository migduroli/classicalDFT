#!/usr/bin/env bash
set -e

source scripts/str_lib.sh
source scripts/format

BUILD_DIR="${BUILD_DIR:-build}"

lint() {
  local fix=false
  if [[ "$1" == "--fix" ]]; then
    fix=true
    shift
  fi

  # Format: check or fix
  if [[ "$fix" == true ]]; then
    format
  else
    format --check
  fi

  message "info" "Lint"

  if [[ ! -f "$BUILD_DIR/compile_commands.json" ]]; then
    message "info" "Building first (compile_commands.json not found)"
    cmake -B "$BUILD_DIR" \
      -DCMAKE_BUILD_TYPE=Release \
      -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
      -DDFT_BUILD_TESTS=ON \
      -DDFT_BUILD_DOCS=OFF \
      -DDFT_USE_GRACE=OFF
    cmake --build "$BUILD_DIR" --parallel
  fi

  local tidy_args=(-p "$BUILD_DIR" --quiet)
  if [[ "$fix" == true ]]; then
    tidy_args+=(--fix)
  fi

  find src -name "*.cpp" | xargs -P"$(nproc)" -n1 clang-tidy "${tidy_args[@]}" 2>&1 | grep -v "warnings generated" || true
  message "success" "Lint completed"
}

if [[ "${#BASH_SOURCE[@]}" -eq 1 ]]; then
  if [[ -f /.dockerenv ]]; then
    lint "$@"
  else
    docker compose run --rm -T app scripts/lint "$@"
  fi
fi
